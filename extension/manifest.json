{
  "manifest_version": 3,
  "name": "Poems Pass — گذرواژه از شعر فارسی",
  "version": "1.0.0",
  "description": "تولید گذرواژه‌ی امن و به‌یادماندنی از شعر و ضرب‌المثل فارسی.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Poems Pass"
  },
  "permissions": ["clipboardWrite"],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
