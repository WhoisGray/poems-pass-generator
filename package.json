{
  "name": "poems-pass-generator",
  "version": "1.0.0",
  "description": "🪶 تولید گذرواژه‌ی امن و به‌یادماندنی از شعر و ضرب‌المثل فارسی — CLI + اکستنشن مرورگر، بدون هیچ وابستگی و بدون نیاز به اینترنت.",
  "type": "module",
  "bin": {
    "ppg": "bin/poems-pass.js",
    "poems-pass": "bin/poems-pass.js"
  },
  "main": "src/core/index.js",
  "exports": {
    ".": "./src/core/index.js"
  },
  "files": [
    "bin",
    "src",
    "data/poems.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/poems-pass.js",
    "build:ext": "node scripts/build-extension.js",
    "icons": "node scripts/make-icons.js",
    "pack:ext": "npm run build:ext && node scripts/pack-extension.js",
    "test": "node test/run.js"
  },
  "keywords": [
    "password",
    "password-generator",
    "passphrase",
    "pwgen",
    "diceware",
    "persian",
    "farsi",
    "poetry",
    "persian-poetry",
    "cli",
    "chrome-extension",
    "browser-extension",
    "security",
    "zero-dependency",
    "offline"
  ],
  "author": "WhoisGray",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WhoisGray/poems-pass-generator.git"
  },
  "bugs": {
    "url": "https://github.com/WhoisGray/poems-pass-generator/issues"
  },
  "homepage": "https://github.com/WhoisGray/poems-pass-generator#readme",
  "engines": {
    "node": ">=18"
  }
}
